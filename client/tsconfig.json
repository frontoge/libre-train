{
	"compilerOptions": {
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"target": "ESNext",
		"module": "ESNext",
		"skipLibCheck": true,
		"jsx": "react-jsx",

		/* Bundler mode */
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"moduleDetection": "force",
		"noEmit": true
	},
	"include": ["src", "vite.config.ts", "eslint.config.ts", "vitest.config.ts"]
}
