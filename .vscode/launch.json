{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "node",
			"request": "launch",
			"name": "Run Vitest (Client)",
			"cwd": "${workspaceFolder}/client",
			"runtimeExecutable": "node",
			"program": "${workspaceFolder}/client/node_modules/vitest/vitest.mjs",
			"args": ["run", "--config", "vitest.config.ts"],
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"noDebug": true
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug Vitest (Client)",
			"cwd": "${workspaceFolder}/client",
			"runtimeExecutable": "node",
			"program": "${workspaceFolder}/client/node_modules/vitest/vitest.mjs",
			"args": ["run", "--config", "vitest.config.ts"],
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Run Vitest (Server)",
			"cwd": "${workspaceFolder}/server",
			"runtimeExecutable": "node",
			"program": "${workspaceFolder}/server/node_modules/vitest/vitest.mjs",
			"args": ["run", "--config", "vitest.config.ts"],
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"noDebug": true
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug Vitest (Server)",
			"cwd": "${workspaceFolder}/server",
			"runtimeExecutable": "node",
			"program": "${workspaceFolder}/server/node_modules/vitest/vitest.mjs",
			"args": ["run", "--config", "vitest.config.ts"],
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"type": "bun",
			"request": "launch",
			"name": "Debug Express (Hot Reload)",
			"program": "${workspaceFolder}/server/index.ts",
			"cwd": "${workspaceFolder}/server",
			"watchMode": "hot", // enables --hot → true hot reloading
			"stopOnEntry": false,
			"args": [], // add any CLI args your index.ts expects
			"runtime": "bun", // usually auto-detected, but safe to set
			"runtimeArgs": [
				// "--inspect",                   // optional – usually not needed with type: bun
				// "--inspect-wait"               // optional – pauses until debugger attaches
			],
			"skipFiles": ["<node_internals>/**", "bun:internal/**"]
		},

		// Fallback: classic attach style (if the above doesn't work smoothly)
		{
			"type": "node",
			"request": "attach",
			"name": "Attach to Bun (after bun --inspect)",
			"port": 6499,
			"skipFiles": ["<node_internals>/**"]
		}
	]
}
