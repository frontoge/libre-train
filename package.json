{
	"name": "libre-train",
	"private": true,
	"version": "0.0.0",
	"workspaces": [
		"client",
		"server",
		"shared"
	],
	"scripts": {
		"clean": "bun run --parallel --no-exit-on-error --workspaces clean",
		"clean:all": "rimraf node_modules bun.lock && bun run --parallel --no-exit-on-error --workspaces clean:all",
		"build": "bun run --filter @libre-train/shared build && bun run --sequential --filter '!@libre-train/shared' build",
		"build:clean": "bun run clean && bun run build",
		"start:client": "bun run --filter @libre-train/client dev",
		"start:server": "bun run --filter @libre-train/server dev",
		"format": "prettier --write \"**/*.{js,ts,tsx,json,css}\"",
		"format:check": "prettier --check \"**/*.{js,ts,tsx,json,css}\"",
		"lint": "bun run --sequential --no-exit-on-error --workspaces lint",
		"lint:fix": "bun run --sequential --no-exit-on-error --workspaces lint:fix",
		"test": "bun run --sequential --no-exit-on-error --filter '!@libre-train/shared' test",
		"test:run": "bun run --sequential --no-exit-on-error --filter '!@libre-train/shared' test:run",
		"test:coverage": "bun run --sequential --no-exit-on-error --filter '!@libre-train/shared' test:coverage"
	},
	"devDependencies": {
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3"
	}
}
