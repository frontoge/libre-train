{
	"name": "libre-train",
	"private": true,
	"version": "0.0.0",
	"workspaces": [
		"client",
		"server",
		"shared",
		"db"
	],
	"scripts": {
		"clean": "bun run --parallel --no-exit-on-error --workspaces clean",
		"clean:all": "rimraf node_modules bun.lock && bun run --parallel --no-exit-on-error --workspaces clean:all",
		"build": "bun run --filter @libre-train/shared build && bun run --sequential --if-present --filter '!@libre-train/shared' build",
		"build:clean": "bun run clean && bun run build",
		"start:client": "bun run --filter @libre-train/client dev",
		"start:server": "bun run --filter @libre-train/server dev",
		"format": "prettier --write \"**/*.{js,ts,tsx,json,css}\"",
		"format:check": "prettier --check \"**/*.{js,ts,tsx,json,css}\"",
		"lint": "bun run --sequential --if-present --no-exit-on-error --filter '!@libre-train/db' lint",
		"lint:fix": "bun run --sequential --if-present --no-exit-on-error --filter '!@libre-train/db' lint:fix",
		"test": "bun run --sequential --if-present --no-exit-on-error --filter '!@libre-train/shared' test",
		"test:run": "bun run --sequential --if-present --no-exit-on-error --filter '!@libre-train/shared' test:run",
		"test:coverage": "bun run --sequential --if-present --no-exit-on-error --filter '!@libre-train/shared' test:coverage",
		"db:generate": "bun run --filter @libre-train/db db:generate",
		"db:deploy": "bun run --filter @libre-train/db db:migrate:deploy"
	},
	"devDependencies": {
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@types/node": "^25.5.2",
		"prettier": "^3.8.1",
		"prisma": "^7.6.0",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"prisma-zod-generator": "^2.1.4",
		"zod": "^4.3.6"
	}
}
