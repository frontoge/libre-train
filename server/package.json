{
	"name": "@libre-train/server",
	"module": "index.ts",
	"type": "module",
	"version": "0.1.0",
	"private": true,
	"devDependencies": {
		"@eslint/js": "^9.39.3",
		"@types/bun": "latest",
		"@types/express": "^5.0.6",
		"eslint": "^9.39.3",
		"express": "^5.2.1",
		"globals": "^16.5.0",
		"rimraf": "^6.1.3",
		"typescript-eslint": "^8.56.1",
		"vitest": "^4.1.2"
	},
	"scripts": {
		"start": "bun run index.ts",
		"dev": "bun --watch index.ts",
		"build": "bun build index.ts --outdir=./dist --target=bun",
		"clean": "rimraf dist",
		"clean:all": "rimraf dist node_modules",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"db:push": "prisma db push",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:migrate:deploy": "prisma migrate deploy",
		"db:migrate:reset": "prisma migrate reset"
	},
	"peerDependencies": {
		"typescript": "^5.8.3"
	},
	"dependencies": {
		"@libre-train/shared": "workspace:*",
		"@prisma/client": "^7.6.0",
		"@prisma/adapter-mariadb": "^7.6.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^24.11.0",
		"argon2": "^0.44.0",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"express-validator": "^7.3.1",
		"jsonwebtoken": "^9.0.3",
		"mysql2": "^3.18.2"
	}
}
