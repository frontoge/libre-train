{
	"compilerOptions": {
		// Environment setup & latest features
		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "ESNext",
		"moduleDetection": "force",
		"allowJs": true,
		"noImplicitAny": true,

		// Bundler mode
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,

		// Best practices
		"strict": true,
		"esModuleInterop": true
	},
	"include": ["**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
